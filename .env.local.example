# Solana RPC (use a paid RPC for production)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Wallet (the user's Jupiter wallet)
NEXT_PUBLIC_WALLET_ADDRESS=<solana-public-key>
WALLET_SECRET_KEY=[<array-of-bytes>]

# Voltr vault address
NEXT_PUBLIC_VOLTR_VAULT_ADDRESS=<vault-address>
